PORT=3000
APP_BASE_URL=https://hotspot.perumnet.id
SESSION_SECRET=ganti-dengan-rahasia-panjang
ADMIN_EMAIL=admin@kopipagi.id
ADMIN_PASSWORD=ganti-kata-sandi-admin
# mock untuk pengembangan; redirect untuk gateway. WiFiDog terdeteksi otomatis
# dari gw_address, gw_port, dan token yang diteruskan oleh Reyee.
REYEE_AUTH_MODE=mock
REYEE_USERNAME_PARAM=username
REYEE_PASSWORD_PARAM=password
REYEE_POST_URL_PARAM=post_url
